within BobLibVehicleInterfaces.Records.VehicleRecord;
package Controllers
  extends BobLibVehicleInterfaces.Icons.RecordsPackageIcon;

  annotation(
    Documentation(info = "<html>
<p>
Package <code>BobLibVehicleInterfaces.Records.VehicleRecord.Controllers</code>
contains controller subsystem parameter records.
</p>
<p>
Records in this package mirror the public controller models and controller
command limits used by vehicle-level experiments.
</p>
</html>"));
end Controllers;
