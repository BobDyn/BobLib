within BobLibVehicleInterfaces.Records.VehicleRecord;
package PowerElectronics
  extends BobLibVehicleInterfaces.Icons.RecordsPackageIcon;

  annotation(
    Documentation(info = "<html>
<p>
Package <code>BobLibVehicleInterfaces.Records.VehicleRecord.PowerElectronics</code>
contains power-electronics subsystem parameter records.
</p>
<p>
Records in this package mirror the public inverter and converter models used
by vehicle-level experiments.
</p>
</html>"));
end PowerElectronics;
