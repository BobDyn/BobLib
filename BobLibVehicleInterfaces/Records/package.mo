within BobLibVehicleInterfaces;
package Records

  "Vehicle parameter records and simulation records"
  extends BobLibVehicleInterfaces.Icons.RecordsPackageIcon;

  annotation(
    preferredView = "info",
    Documentation(info = "<html>
<p>
Vehicle parameter records, visual records, and experiment record definitions.
The icon keeps the standard package shape with the amber color language from
MSL record packages.
</p>
</html>"));
end Records;
