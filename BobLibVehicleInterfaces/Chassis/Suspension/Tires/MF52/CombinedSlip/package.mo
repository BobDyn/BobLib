within BobLibVehicleInterfaces.Chassis.Suspension.Tires.MF52;
package CombinedSlip
  extends BobLibVehicleInterfaces.Icons.BobLibPackageBackground;

  annotation(
    Documentation(info = "<html>
<p>
Package <code>BobLibVehicleInterfaces.Chassis.Suspension.Tires.MF52.CombinedSlip</code> contains Magic Formula 5.2 combined-slip evaluations.
</p>
