within BobLibVehicleInterfaces.Chassis.Suspension.Tires;
package MF52
  extends BobLibVehicleInterfaces.Icons.BobLibPackageBackground;

  annotation(
    Documentation(info = "<html>
<p>
Package <code>BobLibVehicleInterfaces.Chassis.Suspension.Tires.MF52</code> contains Magic Formula 5.2 tire calculations.
</p>
<p>
The package separates coefficient records, slip-state models, pure-slip functions, combined-slip functions, and the aggregate tire evaluator.
</p>
</html>"));
end MF52;
