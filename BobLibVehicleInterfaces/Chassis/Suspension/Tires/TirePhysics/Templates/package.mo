within BobLibVehicleInterfaces.Chassis.Suspension.Tires.TirePhysics;
package Templates

  extends BobLibVehicleInterfaces.Icons.BobLibPackageBackground;

  annotation(
    Documentation(info = "<html>
<p>
Package <code>BobLibVehicleInterfaces.Chassis.Suspension.Tires.TirePhysics.Templates</code> contains wheel-body templates.
</p>
<p>
The partial wheel model defines common frames, states, and outputs shared by 0-DOF, 1-DOF, and 2-DOF wheel variants.
</p>
</html>"));
end Templates;
