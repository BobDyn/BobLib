within BobLibVehicleInterfaces.Chassis.Suspension.Tires;
package TirePhysics
  extends BobLibVehicleInterfaces.Icons.BobLibPackageBackground;

  annotation(
    Documentation(info = "<html>
<p>
Package <code>BobLibVehicleInterfaces.Chassis.Suspension.Tires.TirePhysics</code> contains wheel and tire physical support models.
</p>
<p>
These models represent wheel translation and rotation degrees of freedom that feed the contact and slip calculations.
</p>
</html>"));
end TirePhysics;
