within BobLibVehicleInterfaces.Chassis.Suspension.Templates;
package Stabar
  extends BobLibVehicleInterfaces.Icons.BobLibPackageBackground;

  annotation(
    Documentation(info = "<html>
<p>
Package <code>BobLibVehicleInterfaces.Chassis.Suspension.Templates.Stabar</code> contains reusable suspension templates.
</p>
<p>
Templates describe common double-wishbone, steering-rack, and stabilizer-bar building blocks used by concrete axle models.
</p>
</html>"));
end Stabar;
