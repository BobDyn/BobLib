within BobLibVehicleInterfaces.Chassis.Suspension;
package Linkages

  extends BobLibVehicleInterfaces.Icons.BobLibPackageBackground;

  annotation(
    Documentation(info = "<html>
<p>
Package <code>BobLibVehicleInterfaces.Chassis.Suspension.Linkages</code> contains suspension linkage components.
</p>
<p>
Bellcranks, rods, springs, dampers, and shock linkages are assembled by axle models below the public chassis boundary.
</p>
</html>"));
end Linkages;
