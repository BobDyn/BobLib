within BobLibVehicleInterfaces.Chassis;
package Brakes

  "Simple brake models owned by the chassis domain"
  extends Modelica.Icons.Package;

  annotation(Documentation(info = "<html>
<p>
Package <code>BobLibVehicleInterfaces.Chassis.Brakes</code> contains simple
wheel brake implementations that are physically attached at the chassis wheel
hubs while still exposing the standard VehicleInterfaces brakes boundary.
</p>
</html>"));
end Brakes;
