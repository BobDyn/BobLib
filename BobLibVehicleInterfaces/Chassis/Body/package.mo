within BobLibVehicleInterfaces.Chassis;
package Body

  extends BobLibVehicleInterfaces.Icons.BobLibPackageBackground;

  annotation(
    Documentation(info = "<html>
<p>
Package <code>BobLibVehicleInterfaces.Chassis.Body</code> contains sprung body frame models.
</p>
<p>
These models provide rigid or compliant chassis-frame mass and inertia behavior for the detailed chassis assembly.
</p>
</html>"));
end Body;
