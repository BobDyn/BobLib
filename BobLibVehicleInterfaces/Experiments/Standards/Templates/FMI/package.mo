within BobLibVehicleInterfaces.Experiments.Standards.Templates;

package FMI

  extends BobLibVehicleInterfaces.Icons.BobLibPackageBackground;
  annotation(
    Documentation(info = "<html>
<p>
FMI templates collect FMU/export-oriented vehicle assemblies and supporting
variants. The initial base exposes the minimal driver-command boundary used by
<code>Standards.VehicleFMI</code>: steering wheel, accelerator pedal, and brake
pedal.
</p>
</html>"));
end FMI;
