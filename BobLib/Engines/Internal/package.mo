within BobLib.Engines;
package Internal

  "Internal engine implementation blocks"
  extends BobLib.Icons.BobLibInternalPackageBackground;

  annotation(Documentation(info = "<html>
<p>
Package <code>BobLib.Engines.Internal</code> contains reusable
