within BobLib.Records.VehicleRecord;
package Aero

  extends BobLib.Icons.RecordsPackageIcon;

  annotation(
    Documentation(info = "<html>
<p>
Package <code>BobLib.Records.VehicleRecord.Aero</code> contains aerodynamic parameter records.
</p>
<p>
Aero records store ride-height grids, load tables, and reference conditions consumed by the aero map model.
</p>
</html>"));
end Aero;
