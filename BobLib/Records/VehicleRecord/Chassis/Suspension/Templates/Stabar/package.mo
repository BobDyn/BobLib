within BobLib.Records.VehicleRecord.Chassis.Suspension.Templates;
package Stabar

  extends BobLib.Icons.RecordsPackageIcon;

  annotation(
    Documentation(info = "<html>
<p>
Package <code>BobLib.Records.VehicleRecord.Chassis.Suspension.Templates.Stabar</code>
