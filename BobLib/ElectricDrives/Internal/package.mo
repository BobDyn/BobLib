within BobLib.ElectricDrives;

package Internal

  extends BobLib.Icons.BobLibInternalPackageBackground;
  annotation(
    Documentation(info = "<html>
<p>
Package <code>BobLib.ElectricDrives.Internal</code> contains motor-side implementation models.
</p>
<p>
The models here convert power limits and speed feedback into torque behavior used by the public electric-drive adapter.
</p>
</html>"));
end Internal;
