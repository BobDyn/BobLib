within BobLib.Chassis.Suspension.Tires.MF52;
package SlipModel

  extends BobLib.Icons.BobLibPackageBackground;

  annotation(
    Documentation(info = "<html>
<p>
Package <code>BobLib.Chassis.Suspension.Tires.MF52.SlipModel</code> contains tire slip-state models.
</p>
<p>
Slip models choose whether slip is algebraic, kinematic, or transient before the MF5.2 force and moment equations are evaluated.
</p>
</html>"));
end SlipModel;
