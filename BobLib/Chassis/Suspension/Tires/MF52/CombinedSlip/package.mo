within BobLib.Chassis.Suspension.Tires.MF52;
package CombinedSlip

  extends BobLib.Icons.BobLibPackageBackground;

  annotation(
    Documentation(info = "<html>
<p>
Package <code>BobLib.Chassis.Suspension.Tires.MF52.CombinedSlip</code> contains Magic Formula 5.2 combined-slip evaluations.
</p>
