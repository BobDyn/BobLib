within BobLib.Chassis.Suspension.Templates;
package DoubleWishbone

  extends BobLib.Icons.BobLibPackageBackground;

  annotation(
    Documentation(info = "<html>
<p>
Package <code>BobLib.Chassis.Suspension.Templates.DoubleWishbone</code> contains reusable suspension templates.
</p>
<p>
Templates describe common double-wishbone, steering-rack, and stabilizer-bar building blocks used by concrete axle models.
</p>
</html>"));
end DoubleWishbone;
